{
  "index_patterns": ["ponder-logs-*"],
  "settings": {
    "number_of_shards": 1,
    "number_of_replicas": 0,
    "index.refresh_interval": "5s",
    "index.max_result_window": 50000,
    "analysis": {
      "analyzer": {
        "log_analyzer": {
          "type": "custom",
          "tokenizer": "standard",
          "filter": ["lowercase", "stop"]
        }
      }
    }
  },
  "mappings": {
    "properties": {
      "@timestamp": {
        "type": "date"
      },
      "timestamp": {
        "type": "date"
      },
      "level": {
        "type": "keyword"
      },
      "logger": {
        "type": "keyword"
      },
      "type": {
        "type": "keyword"
      },
      "environment": {
        "type": "keyword"
      },
      "service": {
        "type": "keyword"
      },
      "version": {
        "type": "keyword"
      },
      "tags": {
        "type": "keyword"
      },
      "message": {
        "type": "text",
        "analyzer": "log_analyzer",
        "fields": {
          "keyword": {
            "type": "keyword",
            "ignore_above": 256
          }
        }
      },
      "log_message": {
        "type": "text",
        "analyzer": "log_analyzer",
        "fields": {
          "keyword": {
            "type": "keyword",
            "ignore_above": 1024
          }
        }
      },
      "container_name": {
        "type": "keyword"
      },
      "container_image": {
        "type": "keyword"
      },
      "response": {
        "type": "integer"
      },
      "request_time": {
        "type": "float"
      },
      "duration": {
        "type": "float"
      },
      "severity": {
        "type": "keyword"
      },
      "pid": {
        "type": "keyword"
      },
      "clientip": {
        "type": "ip"
      },
      "verb": {
        "type": "keyword"
      },
      "request": {
        "type": "text",
        "fields": {
          "keyword": {
            "type": "keyword",
            "ignore_above": 512
          }
        }
      },
      "httpversion": {
        "type": "keyword"
      },
      "bytes": {
        "type": "long"
      },
      "referrer": {
        "type": "text",
        "fields": {
          "keyword": {
            "type": "keyword",
            "ignore_above": 256
          }
        }
      },
      "agent": {
        "type": "text",
        "fields": {
          "keyword": {
            "type": "keyword",
            "ignore_above": 256
          }
        }
      }
    }
  }
}